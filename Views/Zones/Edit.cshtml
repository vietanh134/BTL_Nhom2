@model Zone
@{
    ViewData["Title"] = "Sửa vùng nguyên liệu";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-geo-alt-fill text-success me-2"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width: 700px;">
        <div class="card-body-custom">
            <form asp-action="Edit" method="post" class="form-custom">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="TenThonXa" class="form-label"></label>
                    <input asp-for="TenThonXa" class="form-control" />
                    <span asp-validation-for="TenThonXa" class="text-danger"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="HuyenQuan" class="form-label"></label>
                        <input asp-for="HuyenQuan" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TinhThanhPho" class="form-label"></label>
                        <input asp-for="TinhThanhPho" class="form-control" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label"></label>
                    <textarea asp-for="GhiChu" class="form-control" rows="3"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Cập nhật</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
