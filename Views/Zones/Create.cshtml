@model Zone
@{
    ViewData["Title"] = Model.Id == 0 ? "Thêm vùng nguyên liệu" : "Sửa vùng nguyên liệu";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-geo-alt-fill text-success me-2"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width: 700px;">
        <div class="card-body-custom">
            <form asp-action="@(Model.Id == 0 ? "Create" : "Edit")" method="post" class="form-custom">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="TenThonXa" class="form-label"></label>
                    <input asp-for="TenThonXa" class="form-control" placeholder="VD: Xã An Phú" />
                    <span asp-validation-for="TenThonXa" class="text-danger"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="HuyenQuan" class="form-label"></label>
                        <input asp-for="HuyenQuan" class="form-control" placeholder="VD: Huyện Củ Chi" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="TinhThanhPho" class="form-label"></label>
                        <input asp-for="TinhThanhPho" class="form-control" placeholder="VD: TP. Hồ Chí Minh" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label"></label>
                    <textarea asp-for="GhiChu" class="form-control" rows="3" placeholder="Ghi chú thêm..."></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Lưu</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
