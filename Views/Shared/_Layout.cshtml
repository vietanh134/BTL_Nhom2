@{
    ViewData["Title"] = ViewData["Title"] ?? "Trang chủ";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AgriContract</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <div class="app-container">
        <!-- Sidebar -->
        <aside class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <div class="brand">
                    <div class="brand-icon">
                        <i class="bi bi-tree"></i>
                    </div>
                    <div class="brand-text">
                        <h5>AgriContract</h5>
                        <small>Quản lý Bao tiêu</small>
                    </div>
                </div>
            </div>
            <nav class="sidebar-nav">
                <div class="nav-section">
                    <span class="nav-section-title">TỔNG QUAN</span>
                    <a href="@Url.Action("Index", "Home")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")">
                        <i class="bi bi-grid-1x2-fill"></i>
                        <span>Bảng điều khiển</span>
                    </a>
                </div>
                <div class="nav-section">
                    <span class="nav-section-title">QUẢN LÝ</span>
                    <a href="@Url.Action("Index", "Zones")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Zones" ? "active" : "")">
                        <i class="bi bi-geo-alt-fill"></i>
                        <span>Vùng nguyên liệu</span>
                    </a>
                    <a href="@Url.Action("Index", "Farmers")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Farmers" ? "active" : "")">
                        <i class="bi bi-people-fill"></i>
                        <span>Nông dân</span>
                    </a>
                    <a href="@Url.Action("Index", "Supplies")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Supplies" ? "active" : "")">
                        <i class="bi bi-box-seam-fill"></i>
                        <span>Vật tư</span>
                    </a>
                </div>
                <div class="nav-section">
                    <span class="nav-section-title">HỢP ĐỒNG & CÔNG NỢ</span>
                    <a href="@Url.Action("Index", "Contracts")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Contracts" ? "active" : "")">
                        <i class="bi bi-file-earmark-text-fill"></i>
                        <span>Hợp đồng</span>
                    </a>
                    <a href="@Url.Action("Index", "SupplyDebts")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "SupplyDebts" ? "active" : "")">
                        <i class="bi bi-receipt-cutoff"></i>
                        <span>Công nợ vật tư</span>
                    </a>
                    <a href="@Url.Action("Index", "Harvests")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Harvests" ? "active" : "")">
                        <i class="bi bi-basket-fill"></i>
                        <span>Thu mua nông sản</span>
                    </a>
                </div>
                @if (User.IsInRole("Admin"))
                {
                <div class="nav-section">
                    <span class="nav-section-title">HỆ THỐNG</span>
                    <a href="@Url.Action("Index", "Users")" class="nav-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                        <i class="bi bi-shield-lock-fill"></i>
                        <span>Quản lý tài khoản</span>
                    </a>
                </div>
                }
            </nav>
            <div class="sidebar-footer">
                <div class="footer-info" style="flex-direction:column;align-items:stretch;gap:12px">
                    <div style="display:flex;align-items:center;gap:10px;padding-bottom:10px;border-bottom:1px solid rgba(255,255,255,0.08)">
                        <i class="bi bi-person-circle" style="font-size:22px;color:#22c55e"></i>
                        <div>
                            <div style="color:#fff;font-size:13px;font-weight:600">@User.Identity?.Name</div>
                            <div style="font-size:11px;color:rgba(148,163,184,0.6)">@(User.IsInRole("Admin") ? "Quản trị viên" : "Nhân viên")</div>
                        </div>
                    </div>
                    <a href="@Url.Action("Logout","Account")" style="display:flex;align-items:center;gap:8px;color:#f87171;font-size:13px;font-weight:500;text-decoration:none">
                        <i class="bi bi-box-arrow-left"></i> Đăng xuất
                    </a>
                </div>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-content">
            <header class="main-header">
                <button class="btn btn-link sidebar-toggle d-lg-none" onclick="toggleSidebar()">
                    <i class="bi bi-list fs-4"></i>
                </button>
                <div class="header-title">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="header-actions">
                    <span class="text-muted me-3"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dd/MM/yyyy")</span>
                    <span class="text-muted"><i class="bi bi-person-circle"></i> @User.Identity?.Name</span>
                </div>
            </header>

            <div class="content-body">
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                }
                @RenderBody()
            </div>
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
