@model CreateUserViewModel
@{
    ViewData["Title"] = "Thêm tài khoản";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-person-plus-fill text-primary me-2"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width:700px">
        <div class="card-body-custom">
            <form asp-action="Create" method="post" class="form-custom">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="TenDangNhap" class="form-label"></label>
                        <input asp-for="TenDangNhap" class="form-control" placeholder="VD: nhanvien2" />
                        <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="MatKhau" class="form-label"></label>
                        <input asp-for="MatKhau" class="form-control" type="password" placeholder="Tối thiểu 4 ký tự" />
                        <span asp-validation-for="MatKhau" class="text-danger"></span>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="HoTen" class="form-label"></label>
                        <input asp-for="HoTen" class="form-control" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="HoTen" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="VaiTro" class="form-label"></label>
                        <select asp-for="VaiTro" class="form-select">
                            <option value="1">Nhân viên</option>
                            <option value="0">Quản trị viên</option>
                        </select>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="email@example.com" />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SoDienThoai" class="form-label"></label>
                        <input asp-for="SoDienThoai" class="form-control" placeholder="0901234567" />
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Tạo tài khoản</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
