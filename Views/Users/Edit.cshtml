@model User
@{
    ViewData["Title"] = "Sửa tài khoản: " + Model.TenDangNhap;
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-person-gear text-primary me-2"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card-custom">
                <div class="card-header-custom"><h6>Thông tin tài khoản</h6></div>
                <div class="card-body-custom">
                    <form asp-action="Edit" method="post" class="form-custom">
                        <input type="hidden" asp-for="Id" />
                        <input type="hidden" asp-for="MatKhau" />
                        <input type="hidden" asp-for="NgayTao" />
                        <input type="hidden" asp-for="HoatDong" />
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="TenDangNhap" class="form-label"></label>
                                <input asp-for="TenDangNhap" class="form-control" />
                                <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="HoTen" class="form-label"></label>
                                <input asp-for="HoTen" class="form-control" />
                                <span asp-validation-for="HoTen" class="text-danger"></span>
                            </div>
                        </div>
                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label asp-for="Email" class="form-label"></label>
                                <input asp-for="Email" class="form-control" type="email" />
                            </div>
                            <div class="col-md-6">
                                <label asp-for="SoDienThoai" class="form-label"></label>
                                <input asp-for="SoDienThoai" class="form-control" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <label asp-for="VaiTro" class="form-label"></label>
                            <select asp-for="VaiTro" class="form-select">
                                <option value="1">Nhân viên</option>
                                <option value="0">Quản trị viên</option>
                            </select>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Cập nhật</button>
                            <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card-custom">
                <div class="card-header-custom"><h6><i class="bi bi-key me-2"></i>Đặt lại mật khẩu</h6></div>
                <div class="card-body-custom">
                    <form asp-action="ResetPassword" method="post" class="form-custom">
                        <input type="hidden" name="UserId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input type="password" name="MatKhauMoi" class="form-control" placeholder="Tối thiểu 4 ký tự" required minlength="4" />
                        </div>
                        <button type="submit" class="btn-outline-custom" style="border-color:#f59e0b;color:#d97706" onclick="return confirm('Đặt lại mật khẩu cho tài khoản @Model.TenDangNhap?')">
                            <i class="bi bi-key"></i> Đặt lại mật khẩu
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
