@model Harvest
@{
    ViewData["Title"] = "Ghi nhận thu mua";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-basket-fill text-success me-2"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("Index", new{contractId=Model.ContractId > 0 ? Model.ContractId : (int?)null})" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width:700px">
        <div class="card-body-custom">
            <form asp-action="Create" method="post" class="form-custom">
                <div class="mb-3">
                    <label asp-for="ContractId" class="form-label"></label>
                    <select asp-for="ContractId" class="form-select" asp-items="@ViewBag.Contracts">
                        <option value="">-- Chọn hợp đồng --</option>
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="TenNongSan" class="form-label"></label>
                        <input asp-for="TenNongSan" class="form-control" placeholder="VD: Lúa IR50404" />
                        <span asp-validation-for="TenNongSan" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ChatLuong" class="form-label"></label>
                        <select asp-for="ChatLuong" class="form-select">
                            <option value="Loại 1">Loại 1</option>
                            <option value="Loại 2">Loại 2</option>
                            <option value="Loại 3">Loại 3</option>
                        </select>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label asp-for="SoLuong" class="form-label"></label>
                        <input asp-for="SoLuong" class="form-control" type="number" step="0.1" id="harvestQty" />
                        <span asp-validation-for="SoLuong" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="GiaThuMua" class="form-label"></label>
                        <input asp-for="GiaThuMua" class="form-control" type="number" step="100" id="harvestPrice" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Thành tiền</label>
                        <div id="harvestTotal" style="font-size:20px;font-weight:800;color:var(--primary);padding:8px 0">0 VNĐ</div>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="NgayThuMua" class="form-label"></label>
                        <input asp-for="NgayThuMua" class="form-control" type="date" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label"></label>
                    <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Ghi nhận thu mua</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const qtyInput = document.getElementById('harvestQty');
    const priceInput = document.getElementById('harvestPrice');
    const totalEl = document.getElementById('harvestTotal');

    function calcTotal() {
        const total = (parseFloat(qtyInput.value) || 0) * (parseFloat(priceInput.value) || 0);
        totalEl.textContent = total.toLocaleString('vi-VN') + ' VNĐ';
    }
    qtyInput.addEventListener('input', calcTotal);
    priceInput.addEventListener('input', calcTotal);
    calcTotal();
</script>
}
