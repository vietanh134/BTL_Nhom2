@model SupplyDebt
@{
    ViewData["Title"] = "Ghi nợ vật tư";
    var supplyPrices = ViewBag.SupplyPrices as Dictionary<int, decimal> ?? new Dictionary<int, decimal>();
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-receipt-cutoff text-danger me-2"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("Index", new{contractId=Model.ContractId > 0 ? Model.ContractId : (int?)null})" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width:700px">
        <div class="card-body-custom">
            <form asp-action="Create" method="post" class="form-custom">
                <div class="mb-3">
                    <label asp-for="ContractId" class="form-label"></label>
                    <select asp-for="ContractId" class="form-select" asp-items="@ViewBag.Contracts">
                        <option value="">-- Chọn hợp đồng --</option>
                    </select>
                    <span asp-validation-for="ContractId" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="SupplyId" class="form-label"></label>
                    <select asp-for="SupplyId" class="form-select" asp-items="@ViewBag.Supplies" id="supplySelect">
                        <option value="">-- Chọn vật tư --</option>
                    </select>
                    <span asp-validation-for="SupplyId" class="text-danger"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="SoLuong" class="form-label"></label>
                        <input asp-for="SoLuong" class="form-control" type="number" step="0.1" id="quantityInput" />
                        <span asp-validation-for="SoLuong" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Đơn giá (tự động)</label>
                        <input type="text" class="form-control" id="priceDisplay" readonly style="background:#f8fafc;font-weight:700" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold" style="font-size:16px">Thành tiền (ước tính)</label>
                    <div id="totalDisplay" style="font-size:24px;font-weight:800;color:var(--primary)">0 VNĐ</div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="NgayLay" class="form-label"></label>
                        <input asp-for="NgayLay" class="form-control" type="date" />
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label"></label>
                    <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Ghi nợ</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
<script>
    const prices = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(supplyPrices));
    const supplySelect = document.getElementById('supplySelect');
    const quantityInput = document.getElementById('quantityInput');
    const priceDisplay = document.getElementById('priceDisplay');
    const totalDisplay = document.getElementById('totalDisplay');

    function updateTotal() {
        const supplyId = supplySelect.value;
        const qty = parseFloat(quantityInput.value) || 0;
        const price = prices[supplyId] || 0;
        priceDisplay.value = price.toLocaleString('vi-VN') + ' VNĐ';
        const total = qty * price;
        totalDisplay.textContent = total.toLocaleString('vi-VN') + ' VNĐ';
    }

    supplySelect.addEventListener('change', updateTotal);
    quantityInput.addEventListener('input', updateTotal);
    updateTotal();
</script>
}
