@model Farmer
@{
    ViewData["Title"] = "Thêm nông dân";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-people-fill text-success me-2"></i>@ViewData["Title"]</h5>
        <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width:800px">
        <div class="card-body-custom">
            <form asp-action="Create" method="post" class="form-custom">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="HoTen" class="form-label"></label>
                        <input asp-for="HoTen" class="form-control" placeholder="Nguyễn Văn A" />
                        <span asp-validation-for="HoTen" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SoDienThoai" class="form-label"></label>
                        <input asp-for="SoDienThoai" class="form-control" placeholder="0901234567" />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="SoCCCD" class="form-label"></label>
                        <input asp-for="SoCCCD" class="form-control" placeholder="079201001234" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="ZoneId" class="form-label"></label>
                        <select asp-for="ZoneId" class="form-select" asp-items="@ViewBag.Zones">
                            <option value="">-- Chọn vùng --</option>
                        </select>
                        <span asp-validation-for="ZoneId" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="DiaChi" class="form-label"></label>
                    <input asp-for="DiaChi" class="form-control" placeholder="Ấp 1, Xã An Phú" />
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="DienTichCanhTac" class="form-label"></label>
                        <input asp-for="DienTichCanhTac" class="form-control" type="number" step="0.1" />
                        <span asp-validation-for="DienTichCanhTac" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label"></label>
                    <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Lưu</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
