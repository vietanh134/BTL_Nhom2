@model Farmer
@{
    ViewData["Title"] = "Chi tiết nông dân: " + Model.HoTen;
    var tongNo = Model.Contracts.SelectMany(c => c.SupplyDebts).Sum(sd => sd.ThanhTien);
    var tongThuMua = Model.Contracts.SelectMany(c => c.Harvests).Sum(h => h.ThanhTien);
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-person-fill text-success me-2"></i>@Model.HoTen</h5>
        <div class="d-flex gap-2">
            <a href="@Url.Action("Edit", new{id=Model.Id})" class="btn-outline-custom"><i class="bi bi-pencil"></i> Sửa</a>
            <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
        </div>
    </div>

    <div class="card-custom mb-4">
        <div class="card-body-custom">
            <div class="info-grid">
                <div class="info-item"><div class="info-label">Họ và tên</div><div class="info-value">@Model.HoTen</div></div>
                <div class="info-item"><div class="info-label">Số điện thoại</div><div class="info-value">@(Model.SoDienThoai ?? "—")</div></div>
                <div class="info-item"><div class="info-label">CCCD/CMND</div><div class="info-value">@(Model.SoCCCD ?? "—")</div></div>
                <div class="info-item"><div class="info-label">Vùng nguyên liệu</div><div class="info-value"><span class="badge-status active">@Model.Zone?.TenThonXa</span></div></div>
                <div class="info-item"><div class="info-label">Địa chỉ</div><div class="info-value">@(Model.DiaChi ?? "—")</div></div>
                <div class="info-item"><div class="info-label">Diện tích canh tác</div><div class="info-value">@Model.DienTichCanhTac.ToString("N1") ha</div></div>
                <div class="info-item"><div class="info-label">Tổng nợ vật tư</div><div class="info-value money negative">@tongNo.ToString("N0") đ</div></div>
                <div class="info-item"><div class="info-label">Tổng thu mua</div><div class="info-value money positive">@tongThuMua.ToString("N0") đ</div></div>
            </div>
        </div>
    </div>

    <div class="card-custom">
        <div class="card-header-custom">
            <h6><i class="bi bi-file-earmark-text-fill me-2"></i>Danh sách hợp đồng</h6>
            <a href="@Url.Action("Create","Contracts")" class="btn-outline-custom btn-sm"><i class="bi bi-plus"></i> Tạo HĐ mới</a>
        </div>
        <div class="card-body-custom p-0">
            @if (Model.Contracts.Any())
            {
                <table class="table-custom">
                    <thead><tr><th>Mã HĐ</th><th>Mùa vụ</th><th>Sản phẩm</th><th class="text-end">Nợ vật tư</th><th class="text-end">Thu mua</th><th>Trạng thái</th><th></th></tr></thead>
                    <tbody>
                    @foreach (var c in Model.Contracts)
                    {
                        <tr>
                            <td><a href="@Url.Action("Details","Contracts",new{id=c.Id})" class="fw-bold text-decoration-none" style="color:var(--primary)">@c.MaHopDong</a></td>
                            <td>@c.MuaVu</td>
                            <td>@c.SanPhamThuMua</td>
                            <td class="text-end money negative">@c.SupplyDebts.Sum(sd => sd.ThanhTien).ToString("N0")</td>
                            <td class="text-end money positive">@c.Harvests.Sum(h => h.ThanhTien).ToString("N0")</td>
                            <td>
                                @if(c.TrangThai == TrangThaiHopDong.DangThucHien){<span class="badge-status active">Đang thực hiện</span>}
                                else if(c.TrangThai == TrangThaiHopDong.DaQuyetToan){<span class="badge-status settled">Đã quyết toán</span>}
                                else{<span class="badge-status cancelled">Đã hủy</span>}
                            </td>
                            <td><a href="@Url.Action("Details","Contracts",new{id=c.Id})" class="btn-sm-action"><i class="bi bi-eye"></i></a></td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else { <div class="empty-state"><i class="bi bi-file-earmark"></i><p>Chưa có hợp đồng</p></div> }
        </div>
    </div>
</div>
