@model Contract
@{
    ViewData["Title"] = "Sửa hợp đồng";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-file-earmark-text-fill text-success me-2"></i>@ViewData["Title"]: @Model.MaHopDong</h5>
        <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width:800px">
        <div class="card-body-custom">
            <form asp-action="Edit" method="post" class="form-custom">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="NgayTao" />
                <input type="hidden" asp-for="TrangThai" />
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="MaHopDong" class="form-label"></label>
                        <input asp-for="MaHopDong" class="form-control" />
                        <span asp-validation-for="MaHopDong" class="text-danger"></span>
                    </div>
                    <div class="col-md-6">
                        <label asp-for="FarmerId" class="form-label"></label>
                        <select asp-for="FarmerId" class="form-select" asp-items="@ViewBag.Farmers"></select>
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label asp-for="MuaVu" class="form-label"></label>
                        <input asp-for="MuaVu" class="form-control" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="SanPhamThuMua" class="form-label"></label>
                        <input asp-for="SanPhamThuMua" class="form-control" />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label asp-for="GiaThuMua" class="form-label"></label>
                        <input asp-for="GiaThuMua" class="form-control" type="number" step="100" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NgayBatDau" class="form-label"></label>
                        <input asp-for="NgayBatDau" class="form-control" type="date" />
                    </div>
                    <div class="col-md-4">
                        <label asp-for="NgayKetThuc" class="form-label"></label>
                        <input asp-for="NgayKetThuc" class="form-control" type="date" />
                    </div>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label asp-for="LaiSuat" class="form-label"></label>
                        <div class="input-group">
                            <input asp-for="LaiSuat" class="form-control" type="number" step="0.1" />
                            <span class="input-group-text">%/tháng</span>
                        </div>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="GhiChu" class="form-label"></label>
                    <textarea asp-for="GhiChu" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Cập nhật</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
