@model List<Contract>
@{
    ViewData["Title"] = "Hợp đồng";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-file-earmark-text-fill text-success me-2"></i>Danh sách Hợp đồng</h5>
        <a href="@Url.Action("Create")" class="btn-primary-custom"><i class="bi bi-plus-lg"></i> Tạo hợp đồng</a>
    </div>

    <form method="get" class="filter-bar">
        <div class="flex-grow-1" style="min-width:200px">
            <input type="text" name="search" class="form-control" placeholder="🔍 Tìm theo mã HĐ, tên nông dân..." value="@ViewBag.Search" />
        </div>
        <div style="min-width:180px">
            <select name="status" class="form-select">
                <option value="">-- Tất cả trạng thái --</option>
                <option value="0" selected="@(ViewBag.Status != null && (int)ViewBag.Status == 0)">Đang thực hiện</option>
                <option value="1" selected="@(ViewBag.Status != null && (int)ViewBag.Status == 1)">Đã quyết toán</option>
                <option value="2" selected="@(ViewBag.Status != null && (int)ViewBag.Status == 2)">Đã hủy</option>
            </select>
        </div>
        <button type="submit" class="btn-primary-custom"><i class="bi bi-search"></i> Lọc</button>
        <a href="@Url.Action("Index")" class="btn-outline-custom">Xóa lọc</a>
    </form>

    <div class="card-custom">
        <div class="card-body-custom p-0">
            @if (Model.Any())
            {
                <table class="table-custom">
                    <thead>
                        <tr>
                            <th>Mã HĐ</th>
                            <th>Nông dân</th>
                            <th>Vùng</th>
                            <th>Mùa vụ</th>
                            <th>Sản phẩm</th>
                            <th class="text-end">Giá thu mua</th>
                            <th>Thời hạn</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var c in Model)
                    {
                        <tr>
                            <td class="fw-bold"><a href="@Url.Action("Details",new{id=c.Id})" class="text-decoration-none" style="color:var(--primary)">@c.MaHopDong</a></td>
                            <td>@c.Farmer?.HoTen</td>
                            <td><span class="text-muted">@c.Farmer?.Zone?.TenThonXa</span></td>
                            <td>@c.MuaVu</td>
                            <td>@c.SanPhamThuMua</td>
                            <td class="text-end money">@c.GiaThuMua.ToString("N0") đ/kg</td>
                            <td><small>@c.NgayBatDau.ToString("dd/MM/yy") → @c.NgayKetThuc.ToString("dd/MM/yy")</small></td>
                            <td>
                                @if(c.TrangThai == TrangThaiHopDong.DangThucHien){<span class="badge-status active"><i class="bi bi-circle-fill" style="font-size:7px"></i> Đang thực hiện</span>}
                                else if(c.TrangThai == TrangThaiHopDong.DaQuyetToan){<span class="badge-status settled"><i class="bi bi-check-circle-fill" style="font-size:10px"></i> Đã quyết toán</span>}
                                else{<span class="badge-status cancelled"><i class="bi bi-x-circle" style="font-size:10px"></i> Đã hủy</span>}
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-end">
                                    <a href="@Url.Action("Details",new{id=c.Id})" class="btn-sm-action" title="Chi tiết"><i class="bi bi-eye"></i></a>
                                    <a href="@Url.Action("Edit",new{id=c.Id})" class="btn-sm-action" title="Sửa"><i class="bi bi-pencil"></i></a>
                                    <form asp-action="Delete" asp-route-id="@c.Id" method="post" onsubmit="return confirm('Xóa hợp đồng @c.MaHopDong ?')">
                                        <button type="submit" class="btn-sm-action danger" title="Xóa"><i class="bi bi-trash"></i></button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state"><i class="bi bi-file-earmark"></i><p>Chưa có hợp đồng nào</p><a href="@Url.Action("Create")" class="btn-primary-custom"><i class="bi bi-plus-lg"></i> Tạo hợp đồng mới</a></div>
            }
        </div>
    </div>
</div>
