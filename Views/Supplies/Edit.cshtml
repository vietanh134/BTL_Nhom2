@model Supply
@{
    ViewData["Title"] = "Sửa vật tư";
}
<div class="fade-in">
    <div class="page-header">
        <h5><i class="bi bi-box-seam-fill text-success me-2"></i>@ViewData["Title"]: @Model.TenVatTu</h5>
        <a href="@Url.Action("Index")" class="btn-outline-custom"><i class="bi bi-arrow-left"></i> Quay lại</a>
    </div>
    <div class="card-custom" style="max-width:700px">
        <div class="card-body-custom">
            <form asp-action="Edit" method="post" class="form-custom">
                <input type="hidden" asp-for="Id" />
                <div class="mb-3">
                    <label asp-for="TenVatTu" class="form-label"></label>
                    <input asp-for="TenVatTu" class="form-control" />
                    <span asp-validation-for="TenVatTu" class="text-danger"></span>
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label asp-for="LoaiVatTu" class="form-label"></label>
                        <select asp-for="LoaiVatTu" class="form-select">
                            <option value="">-- Chọn --</option>
                            <option value="Giống">Giống</option>
                            <option value="Phân bón">Phân bón</option>
                            <option value="Thuốc BVTV">Thuốc BVTV</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DonViTinh" class="form-label"></label>
                        <input asp-for="DonViTinh" class="form-control" />
                        <span asp-validation-for="DonViTinh" class="text-danger"></span>
                    </div>
                    <div class="col-md-4">
                        <label asp-for="DonGia" class="form-label"></label>
                        <input asp-for="DonGia" class="form-control" type="number" step="100" />
                        <span asp-validation-for="DonGia" class="text-danger"></span>
                    </div>
                </div>
                <div class="mb-3">
                    <label asp-for="MoTa" class="form-label"></label>
                    <textarea asp-for="MoTa" class="form-control" rows="2"></textarea>
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn-primary-custom"><i class="bi bi-check-lg"></i> Cập nhật</button>
                    <a href="@Url.Action("Index")" class="btn-outline-custom">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>
